# Copy this file to ".env" (already gitignored) and fill in your keys.

# Free US Census Bureau Data API key — https://api.census.gov/data/key_signup.html
# Used by workflow/pums-impact.mjs to compute the SF impact stat. Low-sensitivity (rate-limit only).
CENSUS_API_KEY=

# Anthropic API key — https://console.anthropic.com  (SENSITIVE / billable)
# Used server-side by app/api/draft-application.js (form-draft). Never shipped to the browser.
# For local dev put it here; for production set it in Vercel's Environment Variables instead.
ANTHROPIC_API_KEY=
